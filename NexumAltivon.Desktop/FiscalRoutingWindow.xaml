<Window x:Class="NexumAltivon.Desktop.FiscalRoutingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding WindowTitle}"
        Width="1180"
        Height="720"
        MinWidth="980"
        MinHeight="640"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="{StaticResource ShellBackground}"
        FontFamily="Segoe UI">
    <Window.Resources>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBackground}" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Padding" Value="18" />
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
        <Grid Margin="18" MinWidth="940">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="16" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Style="{StaticResource Card}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="FISCAL / MOTOR DE DECISÃO" Foreground="{StaticResource AccentGold}" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding WindowTitle}" Foreground="{StaticResource TextPrimary}" FontSize="30" FontWeight="Bold" Margin="0,6,0,0" />
                        <TextBlock Text="Janela local para calcular e registrar a empresa emissora mais eficiente, considerando custo fiscal, custo logístico e margem da operação." Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" Margin="0,8,0,0" MaxWidth="760" />
                    </StackPanel>
                    <Border Grid.Column="1" Background="{StaticResource PanelSurface}" CornerRadius="14" Padding="14" VerticalAlignment="Center">
                        <StackPanel>
                            <TextBlock Text="{Binding Codigo}" Foreground="{StaticResource TextPrimary}" FontSize="18" FontWeight="Bold" HorizontalAlignment="Right" />
                            <TextBlock Text="Regra fiscal local" Foreground="{StaticResource AccentGreen}" HorizontalAlignment="Right" Margin="0,4,0,0" />
                            <TextBlock Text="{Binding Status}" Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Right" Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="0.8*" />
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Parâmetros fiscais" Foreground="{StaticResource TextPrimary}" FontSize="20" FontWeight="Bold" />
                        <UniformGrid Columns="2" Margin="0,14,0,0">
                            <StackPanel Margin="0,0,12,12">
                                <TextBlock Text="Tipo" Foreground="{StaticResource TextSecondary}" />
                                <ComboBox ItemsSource="{Binding OperationTypes}" SelectedItem="{Binding Tipo}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="Empresa candidata" Foreground="{StaticResource TextSecondary}" />
                                <ComboBox ItemsSource="{Binding Empresas}" SelectedItem="{Binding EmpresaCandidata}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,12,12">
                                <TextBlock Text="Regime fiscal" Foreground="{StaticResource TextSecondary}" />
                                <ComboBox ItemsSource="{Binding Regimes}" SelectedItem="{Binding RegimeFiscal}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="UF destino" Foreground="{StaticResource TextSecondary}" />
                                <TextBox Text="{Binding UfDestino, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,12,12">
                                <TextBlock Text="CFOP" Foreground="{StaticResource TextSecondary}" />
                                <TextBox Text="{Binding Cfop, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="Natureza operação" Foreground="{StaticResource TextSecondary}" />
                                <TextBox Text="{Binding NaturezaOperacao, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,12,12">
                                <TextBlock Text="Valor operação" Foreground="{StaticResource TextSecondary}" />
                                <TextBox Text="{Binding ValorOperacao, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="Margem bruta estimada" Foreground="{StaticResource TextSecondary}" />
                                <TextBox Text="{Binding MargemBrutaEstimada, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,12,12">
                                <TextBlock Text="Custo fiscal estimado" Foreground="{StaticResource TextSecondary}" />
                                <TextBox Text="{Binding CustoFiscalEstimado, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="Custo logístico estimado" Foreground="{StaticResource TextSecondary}" />
                                <TextBox Text="{Binding CustoLogisticoEstimado, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </UniformGrid>

                        <TextBlock Text="Observações" Foreground="{StaticResource TextSecondary}" Margin="0,6,0,5" />
                        <TextBox Text="{Binding Observacoes, UpdateSourceTrigger=PropertyChanged}" Height="100" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Decisão fiscal" Foreground="{StaticResource TextPrimary}" FontSize="20" FontWeight="Bold" />
                        <Border Background="{StaticResource PanelSurface}" CornerRadius="14" Padding="14" Margin="0,14,0,12">
                            <StackPanel>
                                <TextBlock Text="Resultado estimado" Foreground="{StaticResource TextSecondary}" />
                                <TextBlock Text="{Binding ResultadoLabel}" Foreground="{StaticResource TextPrimary}" FontSize="28" FontWeight="Bold" />
                                <TextBlock Text="{Binding Decisao}" Foreground="{StaticResource AccentGold}" TextWrapping="Wrap" FontWeight="SemiBold" Margin="0,8,0,0" />
                            </StackPanel>
                        </Border>
                        <Button Content="Salvar regra fiscal local" Background="{StaticResource AccentGold}" Foreground="#080704" BorderThickness="0" FontWeight="Bold" Click="Salvar_Click" Margin="0,0,0,10" />
                        <Button Content="Calcular melhor empresa emissora" Click="CalcularMelhorEmpresa_Click" Margin="0,0,0,10" />
                        <Button Content="Novo cálculo" Click="Novo_Click" Margin="0,0,0,10" />
                        <Button Content="Fechar" Click="Fechar_Click" />

                        <Border Background="{StaticResource PanelSurface}" CornerRadius="14" Padding="14" Margin="0,18,0,0">
                            <StackPanel>
                                <TextBlock Text="Ranking fiscal e logístico" Foreground="{StaticResource TextSecondary}" />
                                <TextBlock Text="{Binding RankingEmpresas}" Foreground="{StaticResource TextPrimary}" TextWrapping="Wrap" Margin="0,8,0,0" />
                            </StackPanel>
                        </Border>

                        <Border Background="#0C1729" CornerRadius="14" Padding="14" Margin="0,18,0,0">
                            <TextBlock Text="{Binding Status}" Foreground="{StaticResource TextPrimary}" TextWrapping="Wrap" />
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</Window>
