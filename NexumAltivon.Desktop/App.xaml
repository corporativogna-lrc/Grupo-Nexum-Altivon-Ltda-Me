<Application x:Class="NexumAltivon.Desktop.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="ShellBackground" Color="#08111F" />
        <SolidColorBrush x:Key="PanelBackground" Color="#101B30" />
        <SolidColorBrush x:Key="PanelBorder" Color="#22314D" />
        <SolidColorBrush x:Key="TextPrimary" Color="#F8FAFC" />
        <SolidColorBrush x:Key="TextSecondary" Color="#B8C4D6" />
        <SolidColorBrush x:Key="AccentBlue" Color="#38BDF8" />
        <SolidColorBrush x:Key="AccentGreen" Color="#22C55E" />
        <SolidColorBrush x:Key="AccentAmber" Color="#F59E0B" />
        <SolidColorBrush x:Key="AccentRose" Color="#FB7185" />
        <SolidColorBrush x:Key="AccentViolet" Color="#8B5CF6" />
    </Application.Resources>
</Application>
