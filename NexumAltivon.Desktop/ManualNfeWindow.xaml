<Window x:Class="NexumAltivon.Desktop.ManualNfeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Emissão Manual de NF-e"
        Width="1280"
        Height="860"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource ShellBackground}"
        FontFamily="Segoe UI">
    <Grid Margin="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.3*" />
            <ColumnDefinition Width="18" />
            <ColumnDefinition Width="0.9*" />
        </Grid.ColumnDefinitions>

        <Border Background="{StaticResource PanelBackground}" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1" CornerRadius="20" Padding="22">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Emissão manual de NF-e" Foreground="{StaticResource AccentBlue}" FontWeight="SemiBold" />
                    <TextBlock Text="Plano de contingência para quando a automação não estiver pronta." Foreground="{StaticResource TextPrimary}" FontSize="28" FontWeight="Bold" Margin="0,6,0,0" />
                    <TextBlock Text="Esta tela organiza os dados essenciais para preparar a emissão manual, validar custo e deixar o documento pronto para transmissão quando o certificado estiver disponível." Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" Margin="0,10,0,18" />

                    <UniformGrid Columns="2" Rows="3">
                        <StackPanel Margin="0,0,14,14">
                            <TextBlock Text="Empresa emissora" Foreground="{StaticResource TextSecondary}" />
                            <TextBox Text="{Binding EmpresaEmissora}" Padding="12" Background="#0C1729" Foreground="{StaticResource TextPrimary}" BorderBrush="{StaticResource PanelBorder}" />
                        </StackPanel>
                        <StackPanel Margin="0,0,0,14">
                            <TextBlock Text="CNPJ emissor" Foreground="{StaticResource TextSecondary}" />
                            <TextBox Text="{Binding CnpjEmissor}" Padding="12" Background="#0C1729" Foreground="{StaticResource TextPrimary}" BorderBrush="{StaticResource PanelBorder}" />
                        </StackPanel>
                        <StackPanel Margin="0,0,14,14">
                            <TextBlock Text="Cliente destinatário" Foreground="{StaticResource TextSecondary}" />
                            <TextBox Text="{Binding ClienteDestinatario}" Padding="12" Background="#0C1729" Foreground="{StaticResource TextPrimary}" BorderBrush="{StaticResource PanelBorder}" />
                        </StackPanel>
                        <StackPanel Margin="0,0,0,14">
                            <TextBlock Text="CPF/CNPJ destinatário" Foreground="{StaticResource TextSecondary}" />
                            <TextBox Text="{Binding DocumentoDestinatario}" Padding="12" Background="#0C1729" Foreground="{StaticResource TextPrimary}" BorderBrush="{StaticResource PanelBorder}" />
                        </StackPanel>
                        <StackPanel Margin="0,0,14,14">
                            <TextBlock Text="Natureza da operação" Foreground="{StaticResource TextSecondary}" />
                            <TextBox Text="{Binding NaturezaOperacao}" Padding="12" Background="#0C1729" Foreground="{StaticResource TextPrimary}" BorderBrush="{StaticResource PanelBorder}" />
                        </StackPanel>
                        <StackPanel Margin="0,0,0,14">
                            <TextBlock Text="CFOP sugerido" Foreground="{StaticResource TextSecondary}" />
                            <TextBox Text="{Binding Cfop}" Padding="12" Background="#0C1729" Foreground="{StaticResource TextPrimary}" BorderBrush="{StaticResource PanelBorder}" />
                        </StackPanel>
                        <StackPanel Margin="0,0,14,14">
                            <TextBlock Text="Subtotal" Foreground="{StaticResource TextSecondary}" />
                            <TextBox Text="{Binding Subtotal}" Padding="12" Background="#0C1729" Foreground="{StaticResource TextPrimary}" BorderBrush="{StaticResource PanelBorder}" />
                        </StackPanel>
                        <StackPanel Margin="0,0,0,14">
                            <TextBlock Text="Frete" Foreground="{StaticResource TextSecondary}" />
                            <TextBox Text="{Binding Frete}" Padding="12" Background="#0C1729" Foreground="{StaticResource TextPrimary}" BorderBrush="{StaticResource PanelBorder}" />
                        </StackPanel>
                        <StackPanel Margin="0,0,14,14">
                            <TextBlock Text="Impostos estimados" Foreground="{StaticResource TextSecondary}" />
                            <TextBox Text="{Binding ImpostosEstimados}" Padding="12" Background="#0C1729" Foreground="{StaticResource TextPrimary}" BorderBrush="{StaticResource PanelBorder}" />
                        </StackPanel>
                        <StackPanel Margin="0,0,0,14">
                            <TextBlock Text="Margem mínima" Foreground="{StaticResource TextSecondary}" />
                            <TextBox Text="{Binding MargemMinima}" Padding="12" Background="#0C1729" Foreground="{StaticResource TextPrimary}" BorderBrush="{StaticResource PanelBorder}" />
                        </StackPanel>
                    </UniformGrid>

                    <StackPanel Margin="0,0,0,14">
                        <TextBlock Text="Observações fiscais" Foreground="{StaticResource TextSecondary}" />
                        <TextBox Text="{Binding Observacoes}" AcceptsReturn="True" Height="110" Padding="12" Background="#0C1729" Foreground="{StaticResource TextPrimary}" BorderBrush="{StaticResource PanelBorder}" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal">
                        <Button Content="Salvar rascunho" Padding="16,10" Background="{StaticResource AccentBlue}" Foreground="#08111F" BorderThickness="0" FontWeight="SemiBold" Margin="0,0,12,0" Click="SalvarRascunho_Click" />
                        <Button Content="Preparar emissão" Padding="16,10" Background="Transparent" Foreground="{StaticResource TextPrimary}" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1" FontWeight="SemiBold" Click="PrepararEmissao_Click" />
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Border Grid.Column="2" Background="{StaticResource PanelBackground}" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1" CornerRadius="20" Padding="22">
            <StackPanel>
                <TextBlock Text="Prévia executiva" Foreground="{StaticResource TextPrimary}" FontSize="20" FontWeight="Bold" />
                <TextBlock Text="O resumo abaixo ajuda a decidir antes de emitir." Foreground="{StaticResource TextSecondary}" Margin="0,6,0,18" />

                <Border Background="#0C1729" CornerRadius="16" Padding="16" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Situação da emissão" Foreground="{StaticResource AccentAmber}" FontWeight="SemiBold" />
                        <TextBlock Text="Manual e contingencial" Foreground="{StaticResource TextPrimary}" FontSize="18" FontWeight="Bold" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>

                <Border Background="#0C1729" CornerRadius="16" Padding="16" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Critério fiscal" Foreground="{StaticResource AccentBlue}" FontWeight="SemiBold" />
                        <TextBlock Text="A tela força conferência de custo, margem, CFOP e regime antes da transmissão." Foreground="{StaticResource TextPrimary}" TextWrapping="Wrap" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>

                <Border Background="#0C1729" CornerRadius="16" Padding="16" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Dependência restante" Foreground="{StaticResource AccentGreen}" FontWeight="SemiBold" />
                        <TextBlock Text="Certificado digital e autorização SEFAZ continuam obrigatórios para emissão real." Foreground="{StaticResource TextPrimary}" TextWrapping="Wrap" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>

                <Border Background="#0C1729" CornerRadius="16" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Ação recomendada" Foreground="{StaticResource AccentRose}" FontWeight="SemiBold" />
                        <TextBlock Text="Usar esta tela para rascunho e validação quando a automação falhar ou o pedido exigir intervenção manual." Foreground="{StaticResource TextPrimary}" TextWrapping="Wrap" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>

                <Border Background="#0C1729" CornerRadius="16" Padding="16" Margin="0,12,0,0">
                    <StackPanel>
                        <TextBlock Text="Resumo da API" Foreground="{StaticResource AccentGreen}" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding PreviewResumo}" Foreground="{StaticResource TextPrimary}" TextWrapping="Wrap" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</Window>
