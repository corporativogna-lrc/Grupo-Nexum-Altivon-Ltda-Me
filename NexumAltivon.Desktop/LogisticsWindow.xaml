<Window x:Class="NexumAltivon.Desktop.LogisticsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding WindowTitle}"
        Width="1180"
        Height="720"
        MinWidth="980"
        MinHeight="640"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="{StaticResource ShellBackground}"
        FontFamily="Segoe UI">
    <Window.Resources>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBackground}" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Padding" Value="18" />
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
        <Grid Margin="18" MinWidth="940">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="16" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Style="{StaticResource Card}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="LOGÍSTICA / ATENDIMENTO AO PEDIDO" Foreground="{StaticResource AccentGold}" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding WindowTitle}" Foreground="{StaticResource TextPrimary}" FontSize="30" FontWeight="Bold" Margin="0,6,0,0" />
                        <TextBlock Text="Operação local de coleta, entrega, rastreamento, transportadora, atualização de pedido e aviso ao cliente." Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" Margin="0,8,0,0" MaxWidth="760" />
                    </StackPanel>
                    <Border Grid.Column="1" Background="{StaticResource PanelSurface}" CornerRadius="14" Padding="14" VerticalAlignment="Center">
                        <StackPanel>
                            <TextBlock Text="{Binding Codigo}" Foreground="{StaticResource TextPrimary}" FontSize="18" FontWeight="Bold" HorizontalAlignment="Right" />
                            <TextBlock Text="Operação logística local" Foreground="{StaticResource AccentGreen}" HorizontalAlignment="Right" Margin="0,4,0,0" />
                            <TextBlock Text="{Binding Status}" Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Right" Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="0.8*" />
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Dados logísticos" Foreground="{StaticResource TextPrimary}" FontSize="20" FontWeight="Bold" />
                        <UniformGrid Columns="2" Margin="0,14,0,0">
                            <StackPanel Margin="0,0,12,12">
                                <TextBlock Text="Tipo" Foreground="{StaticResource TextSecondary}" />
                                <ComboBox ItemsSource="{Binding OperationTypes}" SelectedItem="{Binding Tipo}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="Status entrega" Foreground="{StaticResource TextSecondary}" />
                                <ComboBox ItemsSource="{Binding StatusOptions}" SelectedItem="{Binding StatusEntrega}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,12,12">
                                <TextBlock Text="Pedido referência" Foreground="{StaticResource TextSecondary}" />
                                <TextBox Text="{Binding PedidoReferencia, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="Cliente destino" Foreground="{StaticResource TextSecondary}" />
                                <TextBox Text="{Binding ClienteDestino, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,12,12">
                                <TextBlock Text="Transportadora" Foreground="{StaticResource TextSecondary}" />
                                <TextBox Text="{Binding Transportadora, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="Custo frete" Foreground="{StaticResource TextSecondary}" />
                                <TextBox Text="{Binding CustoFrete, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,12,12">
                                <TextBlock Text="Origem" Foreground="{StaticResource TextSecondary}" />
                                <TextBox Text="{Binding Origem, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="Destino" Foreground="{StaticResource TextSecondary}" />
                                <TextBox Text="{Binding Destino, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,12,12">
                                <TextBlock Text="Previsão coleta" Foreground="{StaticResource TextSecondary}" />
                                <DatePicker SelectedDate="{Binding PrevisaoColeta}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="Previsão entrega" Foreground="{StaticResource TextSecondary}" />
                                <DatePicker SelectedDate="{Binding PrevisaoEntrega}" />
                            </StackPanel>
                        </UniformGrid>

                        <CheckBox Content="Notificar cliente por WhatsApp/e-mail quando sincronizar" IsChecked="{Binding NotificarCliente}" Foreground="{StaticResource TextPrimary}" Margin="0,6,0,10" />
                        <TextBlock Text="Canal de notificação" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,5" />
                        <ComboBox ItemsSource="{Binding NotificationChannels}" SelectedItem="{Binding CanalNotificacao}" />
                        <TextBlock Text="Observações" Foreground="{StaticResource TextSecondary}" Margin="0,10,0,5" />
                        <TextBox Text="{Binding Observacoes, UpdateSourceTrigger=PropertyChanged}" Height="90" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Acompanhamento" Foreground="{StaticResource TextPrimary}" FontSize="20" FontWeight="Bold" />
                        <Border Background="{StaticResource PanelSurface}" CornerRadius="14" Padding="14" Margin="0,14,0,12">
                            <StackPanel>
                                <TextBlock Text="Prazo previsto" Foreground="{StaticResource TextSecondary}" />
                                <TextBlock Text="{Binding PrazoLabel}" Foreground="{StaticResource TextPrimary}" FontSize="28" FontWeight="Bold" />
                                <TextBlock Text="{Binding ComunicaçãoLabel}" Foreground="{StaticResource AccentGold}" TextWrapping="Wrap" FontWeight="SemiBold" Margin="0,8,0,0" />
                            </StackPanel>
                        </Border>
                        <Button Content="Salvar operação logística" Background="{StaticResource AccentGold}" Foreground="#080704" BorderThickness="0" FontWeight="Bold" Click="Salvar_Click" Margin="0,0,0,10" />
                        <Button Content="Nova operação" Click="Novo_Click" Margin="0,0,0,10" />
                        <Button Content="Fechar" Click="Fechar_Click" />

                        <Border Background="#0C1729" CornerRadius="14" Padding="14" Margin="0,18,0,0">
                            <TextBlock Text="{Binding Status}" Foreground="{StaticResource TextPrimary}" TextWrapping="Wrap" />
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</Window>
