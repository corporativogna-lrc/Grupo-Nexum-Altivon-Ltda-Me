<Window x:Class="NexumAltivon.Desktop.LogisticsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GenesisGest.Net - Expedição e rastreamento"
        Width="1360"
        Height="820"
        MinWidth="1120"
        MinHeight="700"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="{StaticResource ShellBackground}"
        FontFamily="Segoe UI"
        Loaded="Window_Loaded">
    <Window.Resources>
        <Style x:Key="Panel" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBackground}" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="16" />
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,5" />
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource Panel}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="EXPEDIÇÃO E RASTREAMENTO" Foreground="{StaticResource AccentGold}" FontWeight="Bold" />
                    <TextBlock Text="{Binding CodigoContexto}" Foreground="{StaticResource TextPrimary}" FontSize="26" FontWeight="Bold" Margin="0,4,0,0" />
                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                        <TextBlock Text="{Binding TenantLabel}" Foreground="{StaticResource TextSecondary}" />
                        <TextBlock Text="  |  " Foreground="{StaticResource TextSecondary}" />
                        <TextBlock Text="{Binding EstadoContexto}" Foreground="{StaticResource AccentGreen}" FontWeight="SemiBold" />
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Recarregar" Click="Recarregar_Click" IsEnabled="{Binding PodeOperar}" Margin="0,0,8,0" MinWidth="110" />
                    <Button Content="Avançar fluxo" Click="AvancarFluxo_Click" IsEnabled="{Binding PodeOperar}" Background="{StaticResource AccentGreen}" Foreground="#06110C" BorderThickness="0" FontWeight="Bold" MinWidth="130" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.55*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="0.85*" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource Panel}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="190" />
                    </Grid.RowDefinitions>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Pedidos em operação" Foreground="{StaticResource TextPrimary}" FontSize="18" FontWeight="Bold" />
                        <TextBlock Grid.Column="1" Text="{Binding QuantidadeLabel}" Foreground="{StaticResource TextSecondary}" />
                    </Grid>
                    <DataGrid Grid.Row="2"
                              ItemsSource="{Binding Expedicoes}"
                              SelectedItem="{Binding SelectedExpedicao}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              HeadersVisibility="Column"
                              CanUserAddRows="False"
                              ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                              ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Pedido" Binding="{Binding NumeroPedido}" Width="145" />
                            <DataGridTextColumn Header="Cliente" Binding="{Binding ClienteNome}" Width="*" />
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="110" />
                            <DataGridTextColumn Header="Transportadora" Binding="{Binding FreteTransportadora}" Width="130" />
                            <DataGridTextColumn Header="Rastreio" Binding="{Binding FreteCodigoRastreio}" Width="140" />
                            <DataGridTextColumn Header="Último evento" Binding="{Binding UltimoStatusExterno}" Width="130" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <Grid Grid.Row="4">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="Eventos confirmados pelo provedor" Foreground="{StaticResource TextPrimary}" FontSize="16" FontWeight="Bold" />
                        <DataGrid Grid.Row="2"
                                  ItemsSource="{Binding Eventos}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  HeadersVisibility="Column"
                                  CanUserAddRows="False"
                                  ScrollViewer.HorizontalScrollBarVisibility="Hidden">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Data/hora" Binding="{Binding DataHora, StringFormat={}{0:dd/MM/yyyy HH:mm}}" Width="135" />
                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="135" />
                                <DataGridTextColumn Header="Local" Binding="{Binding Local}" Width="120" />
                                <DataGridTextColumn Header="Descrição" Binding="{Binding Descricao}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource Panel}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="18" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="Cabeçalho da expedição" Foreground="{StaticResource TextPrimary}" FontSize="18" FontWeight="Bold" />
                        <TextBlock Text="{Binding PedidoSelecionadoLabel}" Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" Margin="0,4,0,0" />
                    </StackPanel>
                    <StackPanel Grid.Row="2">
                        <TextBlock Text="Método de frete" Style="{StaticResource FieldLabel}" />
                        <TextBox Text="{Binding FreteMetodo, UpdateSourceTrigger=PropertyChanged}" MaxLength="50" />
                    </StackPanel>
                    <StackPanel Grid.Row="4">
                        <TextBlock Text="Transportadora" Style="{StaticResource FieldLabel}" />
                        <TextBox Text="{Binding FreteTransportadora, UpdateSourceTrigger=PropertyChanged}" MaxLength="50" />
                    </StackPanel>
                    <StackPanel Grid.Row="6">
                        <TextBlock Text="Código de rastreio" Style="{StaticResource FieldLabel}" />
                        <TextBox Text="{Binding FreteCodigoRastreio, UpdateSourceTrigger=PropertyChanged}" MaxLength="50" />
                    </StackPanel>
                    <StackPanel Grid.Row="8">
                        <TextBlock Text="Prazo em dias" Style="{StaticResource FieldLabel}" />
                        <TextBox Text="{Binding FretePrazoDias, UpdateSourceTrigger=PropertyChanged}" MaxLength="3" />
                    </StackPanel>

                    <Button Grid.Row="10" Content="Salvar no pedido" Click="Salvar_Click" IsEnabled="{Binding PodeOperar}" Background="{StaticResource AccentGold}" Foreground="#080704" BorderThickness="0" FontWeight="Bold" />
                    <Button Grid.Row="12" Content="Consultar provedor" Click="ConsultarRastreamento_Click" IsEnabled="{Binding PodeOperar}" />

                    <Border Grid.Row="14" Background="{StaticResource PanelSurface}" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1" CornerRadius="8" Padding="12">
                        <StackPanel>
                            <TextBlock Text="Resultado operacional" Foreground="{StaticResource AccentGold}" FontWeight="Bold" />
                            <TextBlock Text="{Binding Status}" Foreground="{StaticResource TextPrimary}" TextWrapping="Wrap" Margin="0,6,0,0" />
                            <Button Content="Fechar" Click="Fechar_Click" Margin="0,12,0,0" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="4" Background="#0C1729" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1" CornerRadius="8" Padding="10">
            <TextBlock Text="{Binding Status}" Foreground="{StaticResource TextPrimary}" TextWrapping="Wrap" />
        </Border>
    </Grid>
</Window>
