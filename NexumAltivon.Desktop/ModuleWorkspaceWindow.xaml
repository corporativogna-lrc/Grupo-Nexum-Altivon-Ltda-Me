<Window x:Class="NexumAltivon.Desktop.ModuleWorkspaceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding WindowTitle}"
        Width="1040"
        Height="660"
        MinWidth="900"
        MinHeight="580"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="{StaticResource ShellBackground}"
        FontFamily="Segoe UI">
    <Window.Resources>
        <Style x:Key="WorkspaceCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBackground}" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Padding" Value="18" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="11" />
            <Setter Property="Background" Value="#0C1729" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorder}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Auto">
        <Grid Margin="18" MinWidth="880">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="16" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Style="{StaticResource WorkspaceCard}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="{Binding Area}" Foreground="{StaticResource AccentGold}" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding ModuleTitle}" Foreground="{StaticResource TextPrimary}" FontSize="30" FontWeight="Bold" Margin="0,6,0,0" />
                        <TextBlock Text="{Binding Detail}" Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" Margin="0,8,0,0" MaxWidth="720" />
                    </StackPanel>
                    <Border Grid.Column="1" Background="{StaticResource PanelSurface}" CornerRadius="14" Padding="14" VerticalAlignment="Center">
                        <StackPanel>
                            <TextBlock Text="Janela local individual" Foreground="{StaticResource AccentGreen}" FontWeight="SemiBold" HorizontalAlignment="Right" />
                            <TextBlock Text="GenesisGest.Net" Foreground="{StaticResource TextPrimary}" FontSize="18" FontWeight="Bold" Margin="0,4,0,0" HorizontalAlignment="Right" />
                            <TextBlock Text="Aplicação desktop, sem navegador" Foreground="{StaticResource TextSecondary}" Margin="0,4,0,0" HorizontalAlignment="Right" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.1*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="0.9*" />
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource WorkspaceCard}">
                    <StackPanel>
                        <TextBlock Text="Contexto operacional" Foreground="{StaticResource TextPrimary}" FontSize="20" FontWeight="Bold" />
                            <TextBlock Text="Esta janela registra solicitações operacionais no servidor Genesis e mantém contingência local identificada quando a API estiver indisponível." Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" Margin="0,8,0,16" />

                        <UniformGrid Columns="2">
                            <StackPanel Margin="0,0,12,12">
                                <TextBlock Text="Código / referência" Foreground="{StaticResource TextSecondary}" />
                                <TextBox Text="{Binding ReferenceCode}" IsReadOnly="True" />
                            </StackPanel>
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="Origem" Foreground="{StaticResource TextSecondary}" />
                                <TextBox Text="{Binding Source}" IsReadOnly="True" />
                            </StackPanel>
                            <StackPanel Margin="0,0,12,12">
                                <TextBlock Text="Empresa" Foreground="{StaticResource TextSecondary}" />
                                <TextBox Text="Grupo Nexum Altivon" IsReadOnly="True" />
                            </StackPanel>
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="Banco interno" Foreground="{StaticResource TextSecondary}" />
                                <TextBox Text="{Binding ServerDatabase}" IsReadOnly="True" />
                            </StackPanel>
                        </UniformGrid>

                        <Border Background="{StaticResource PanelSurface}" CornerRadius="14" Padding="14" Margin="0,6,0,0">
                            <TextBlock Text="{Binding ExecutionPolicy}" Foreground="{StaticResource AccentGold}" TextWrapping="Wrap" FontWeight="SemiBold" />
                        </Border>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource WorkspaceCard}">
                    <StackPanel>
                        <TextBlock Text="Ações disponíveis" Foreground="{StaticResource TextPrimary}" FontSize="20" FontWeight="Bold" />
                        <TextBlock Text="O resultado diferencia gravação confirmada no servidor, contingência local e falha, incluindo a referência persistida." Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" Margin="0,8,0,16" />

                        <Button Content="Registrar solicitação operacional"
                                Padding="16,10"
                                Background="{StaticResource AccentGold}"
                                Foreground="#080704"
                                FontWeight="Bold"
                                BorderThickness="0"
                                Margin="0,0,0,10"
                                Click="ConfirmarOperacao_Click" />
                        <Button Content="Atualizar vínculo com servidor"
                                Padding="16,10"
                                Background="{StaticResource PanelSurface}"
                                Foreground="{StaticResource TextPrimary}"
                                BorderBrush="{StaticResource PanelBorder}"
                                BorderThickness="1"
                                Margin="0,0,0,10"
                                Click="AtualizarVinculo_Click" />
                        <Button Content="Fechar"
                                Padding="16,10"
                                Background="Transparent"
                                Foreground="{StaticResource TextPrimary}"
                                BorderBrush="{StaticResource PanelBorder}"
                                BorderThickness="1"
                                Click="Fechar_Click" />

                        <Border Background="#0C1729" CornerRadius="14" Padding="14" Margin="0,18,0,0">
                            <StackPanel>
                                <TextBlock Text="Status" Foreground="{StaticResource AccentGreen}" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding Status}" Foreground="{StaticResource TextPrimary}" TextWrapping="Wrap" Margin="0,5,0,0" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</Window>
