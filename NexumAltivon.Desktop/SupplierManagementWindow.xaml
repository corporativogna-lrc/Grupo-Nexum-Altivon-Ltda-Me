<Window x:Class="NexumAltivon.Desktop.SupplierManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GenesisGest.Net - Fornecedores"
        Width="1280"
        Height="760"
        MinWidth="1080"
        MinHeight="680"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{StaticResource ShellBackground}"
        FontFamily="Segoe UI">
    <Window.Resources>
        <Style x:Key="SectionBorder" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBackground}" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="14" />
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="MinWidth" Value="108" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Margin" Value="8,0,0,0" />
            <Setter Property="Padding" Value="12,0" />
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="92" />
            <RowDefinition Height="10" />
            <RowDefinition Height="*" />
            <RowDefinition Height="10" />
            <RowDefinition Height="42" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource SectionBorder}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="MASTER DATA / FORNECEDORES" Foreground="{StaticResource AccentGold}" FontSize="12" FontWeight="SemiBold" />
                    <TextBlock Text="Cadastro e contatos de fornecedores" Foreground="{StaticResource TextPrimary}" FontSize="24" FontWeight="Bold" Margin="0,3,0,0" />
                    <TextBlock Text="Persistência oficial com JWT, tenant, concorrência, auditoria e releitura após cada gravação."
                               Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,3,0,0" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Atualizar" Style="{StaticResource ActionButton}" IsEnabled="{Binding CanOperate}" Click="Atualizar_Click" />
                    <Button Content="Novo fornecedor" Style="{StaticResource ActionButton}" IsEnabled="{Binding CanOperate}" Click="NovoFornecedor_Click" />
                    <Button Content="Salvar fornecedor" Style="{StaticResource ActionButton}" IsEnabled="{Binding CanOperate}"
                            Background="{StaticResource AccentGold}" Foreground="#080704" BorderThickness="0" FontWeight="Bold" Click="SalvarFornecedor_Click" />
                    <Button Content="Fechar" Style="{StaticResource ActionButton}" Click="Fechar_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <TabControl Grid.Row="2" SelectedIndex="{Binding SelectedTabIndex}">
            <TabItem Header="Cadastro">
                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="0.9*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="1.4*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource SectionBorder}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Fornecedores persistidos" Foreground="{StaticResource TextPrimary}" FontSize="16" FontWeight="Bold" />
                                <TextBlock Grid.Column="1" Text="{Binding FornecedorCountLabel}" Foreground="{StaticResource AccentGold}" FontWeight="SemiBold" />
                            </Grid>
                            <DataGrid Grid.Row="2"
                                      ItemsSource="{Binding Fornecedores}"
                                      SelectedItem="{Binding SelectedFornecedor, Mode=TwoWay}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      SelectionMode="Single"
                                      SelectionUnit="FullRow"
                                      HeadersVisibility="Column"
                                      CanUserAddRows="False">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="54" />
                                    <DataGridTextColumn Header="Fornecedor" Binding="{Binding Nome}" Width="*" />
                                    <DataGridTextColumn Header="Documento" Binding="{Binding Documento}" Width="120" />
                                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="88" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource SectionBorder}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="10" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="10" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="10" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Cabeçalho cadastral" Foreground="{StaticResource TextPrimary}" FontSize="16" FontWeight="Bold" />
                                    <TextBlock Text="{Binding CadastroReference}" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,3,0,0" />
                                </StackPanel>
                                <Border Grid.Column="1" Background="{StaticResource PanelSurface}" CornerRadius="6" Padding="10,6">
                                    <TextBlock Text="{Binding RowVersionLabel}" Foreground="{StaticResource AccentGold}" FontSize="11" />
                                </Border>
                            </Grid>

                            <UniformGrid Grid.Row="2" Columns="4">
                                <StackPanel Margin="0,0,10,8">
                                    <TextBlock Text="Razão social *" Style="{StaticResource FieldLabel}" />
                                    <TextBox Text="{Binding RazaoSocial, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel Margin="0,0,10,8">
                                    <TextBlock Text="Nome fantasia" Style="{StaticResource FieldLabel}" />
                                    <TextBox Text="{Binding NomeFantasia, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel Margin="0,0,10,8">
                                    <TextBlock Text="CNPJ / CPF" Style="{StaticResource FieldLabel}" />
                                    <TextBox Text="{Binding Documento, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel Margin="0,0,0,8">
                                    <TextBlock Text="Inscrição estadual" Style="{StaticResource FieldLabel}" />
                                    <TextBox Text="{Binding InscricaoEstadual, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel Margin="0,0,10,8">
                                    <TextBlock Text="E-mail comercial" Style="{StaticResource FieldLabel}" />
                                    <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel Margin="0,0,10,8">
                                    <TextBlock Text="Telefone" Style="{StaticResource FieldLabel}" />
                                    <TextBox Text="{Binding Telefone, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel Margin="0,0,10,8">
                                    <TextBlock Text="WhatsApp" Style="{StaticResource FieldLabel}" />
                                    <TextBox Text="{Binding Whatsapp, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel Margin="0,0,0,8">
                                    <TextBlock Text="Segmento" Style="{StaticResource FieldLabel}" />
                                    <TextBox Text="{Binding Segmento, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </UniformGrid>

                            <UniformGrid Grid.Row="4" Columns="4">
                                <StackPanel Margin="0,0,10,8">
                                    <TextBlock Text="Endereço" Style="{StaticResource FieldLabel}" />
                                    <TextBox Text="{Binding Endereco, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel Margin="0,0,10,8">
                                    <TextBlock Text="Cidade" Style="{StaticResource FieldLabel}" />
                                    <TextBox Text="{Binding Cidade, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel Margin="0,0,10,8">
                                    <TextBlock Text="UF" Style="{StaticResource FieldLabel}" />
                                    <TextBox Text="{Binding Estado, UpdateSourceTrigger=PropertyChanged}" MaxLength="2" />
                                </StackPanel>
                                <StackPanel Margin="0,0,0,8">
                                    <TextBlock Text="CEP" Style="{StaticResource FieldLabel}" />
                                    <TextBox Text="{Binding Cep, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel Margin="0,0,10,0">
                                    <TextBlock Text="Loja vinculada (ID)" Style="{StaticResource FieldLabel}" />
                                    <TextBox Text="{Binding LojaVinculadaIdText, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel Margin="0,0,10,0">
                                    <TextBlock Text="Comissão (%)" Style="{StaticResource FieldLabel}" />
                                    <TextBox Text="{Binding ComissaoPercentualText, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel Margin="0,0,10,0">
                                    <TextBlock Text="Prazo entrega (dias)" Style="{StaticResource FieldLabel}" />
                                    <TextBox Text="{Binding PrazoEntregaDiasText, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="Status" Style="{StaticResource FieldLabel}" />
                                    <ComboBox ItemsSource="{Binding StatusOptions}" SelectedItem="{Binding FornecedorStatus}" />
                                </StackPanel>
                            </UniformGrid>

                            <Grid Grid.Row="6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="240" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Observações" Style="{StaticResource FieldLabel}" />
                                    <TextBox Text="{Binding Observacoes, UpdateSourceTrigger=PropertyChanged}"
                                             AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />
                                </StackPanel>
                                <Border Grid.Column="2" Background="{StaticResource PanelSurface}" CornerRadius="6" Padding="12">
                                    <StackPanel>
                                        <TextBlock Text="Validação operacional" Foreground="{StaticResource TextSecondary}" FontSize="11" />
                                        <TextBlock Text="{Binding CadastroValidation}" Foreground="{StaticResource TextPrimary}" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,4,0,0" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Contatos" IsEnabled="{Binding HasPersistedFornecedor}">
                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.2*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="0.8*" />
                    </Grid.ColumnDefinitions>
                    <Border Style="{StaticResource SectionBorder}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="{Binding ContactHeader}" Foreground="{StaticResource TextPrimary}" FontSize="16" FontWeight="Bold" />
                            <DataGrid Grid.Row="2"
                                      ItemsSource="{Binding Contatos}"
                                      SelectedItem="{Binding SelectedContato, Mode=TwoWay}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      SelectionMode="Single"
                                      SelectionUnit="FullRow"
                                      CanUserAddRows="False">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Nome" Binding="{Binding Nome}" Width="*" />
                                    <DataGridTextColumn Header="Cargo" Binding="{Binding Cargo}" Width="150" />
                                    <DataGridTextColumn Header="E-mail" Binding="{Binding Email}" Width="190" />
                                    <DataGridCheckBoxColumn Header="Principal" Binding="{Binding Principal}" Width="78" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                    <Border Grid.Column="2" Style="{StaticResource SectionBorder}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="10" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="10" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="Contato do fornecedor" Foreground="{StaticResource TextPrimary}" FontSize="16" FontWeight="Bold" />
                            <UniformGrid Grid.Row="2" Columns="2">
                                <StackPanel Margin="0,0,10,8">
                                    <TextBlock Text="Nome *" Style="{StaticResource FieldLabel}" />
                                    <TextBox Text="{Binding ContatoNome, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel Margin="0,0,0,8">
                                    <TextBlock Text="Cargo" Style="{StaticResource FieldLabel}" />
                                    <TextBox Text="{Binding ContatoCargo, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel Margin="0,0,10,8">
                                    <TextBlock Text="E-mail" Style="{StaticResource FieldLabel}" />
                                    <TextBox Text="{Binding ContatoEmail, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel Margin="0,0,0,8">
                                    <TextBlock Text="Telefone" Style="{StaticResource FieldLabel}" />
                                    <TextBox Text="{Binding ContatoTelefone, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel Margin="0,0,10,0">
                                    <TextBlock Text="Celular" Style="{StaticResource FieldLabel}" />
                                    <TextBox Text="{Binding ContatoCelular, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel VerticalAlignment="Bottom">
                                    <CheckBox Content="Contato principal" IsChecked="{Binding ContatoPrincipal}" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,6" />
                                    <CheckBox Content="Contato ativo" IsChecked="{Binding ContatoAtivo}" Foreground="{StaticResource TextPrimary}" />
                                </StackPanel>
                            </UniformGrid>
                            <Border Grid.Row="4" Background="{StaticResource PanelSurface}" CornerRadius="6" Padding="10">
                                <TextBlock Text="{Binding ContactVersionLabel}" Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" />
                            </Border>
                            <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="Novo contato" Style="{StaticResource ActionButton}" IsEnabled="{Binding CanOperate}" Click="NovoContato_Click" />
                                <Button Content="Desativar" Style="{StaticResource ActionButton}" IsEnabled="{Binding CanOperate}" Click="DesativarContato_Click" />
                                <Button Content="Salvar contato" Style="{StaticResource ActionButton}" IsEnabled="{Binding CanOperate}"
                                        Background="{StaticResource AccentGold}" Foreground="#080704" BorderThickness="0" FontWeight="Bold" Click="SalvarContato_Click" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Trilha de auditoria" IsEnabled="{Binding HasPersistedFornecedor}">
                <Border Margin="0,10,0,0" Style="{StaticResource SectionBorder}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="Gravações confirmadas na auditoria" Foreground="{StaticResource TextPrimary}" FontSize="16" FontWeight="Bold" />
                        <DataGrid Grid.Row="2" ItemsSource="{Binding Auditoria}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Data" Binding="{Binding CreatedAt, StringFormat={}{0:dd/MM/yyyy HH:mm:ss}}" Width="160" />
                                <DataGridTextColumn Header="Tabela" Binding="{Binding Tabela}" Width="190" />
                                <DataGridTextColumn Header="Registro" Binding="{Binding RegistroId}" Width="90" />
                                <DataGridTextColumn Header="Ação" Binding="{Binding Acao}" Width="110" />
                                <DataGridTextColumn Header="Usuário" Binding="{Binding UsuarioId}" Width="90" />
                                <DataGridTextColumn Header="Endpoint" Binding="{Binding Endpoint}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </TabItem>
        </TabControl>

        <Border Grid.Row="4" Background="{StaticResource PanelSurface}" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1" CornerRadius="6" Padding="12,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding Status}" Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                <TextBlock Grid.Column="1" Text="{Binding TenantLabel}" Foreground="{StaticResource AccentGold}" VerticalAlignment="Center" FontWeight="SemiBold" />
            </Grid>
        </Border>
    </Grid>
</Window>
