<Window x:Class="NexumAltivon.Desktop.CorporateMasterDataWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding WindowTitle}"
        Width="1220"
        Height="760"
        MinWidth="1020"
        MinHeight="660"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="{StaticResource ShellBackground}"
        FontFamily="Segoe UI">
    <Window.Resources>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBackground}" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Padding" Value="18" />
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
        <Grid Margin="18" MinWidth="980">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="16" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Style="{StaticResource Card}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="MASTER DATA CORPORATIVO" Foreground="{StaticResource AccentGold}" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding WindowTitle}" Foreground="{StaticResource TextPrimary}" FontSize="30" FontWeight="Bold" Margin="0,6,0,0" />
                        <TextBlock Text="Cadastro único com dados fiscais, comerciais, contábeis, operacionais, acesso e RH para alimentar GenesisGest.Net e Nexum." Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" Margin="0,8,0,0" MaxWidth="780" />
                    </StackPanel>
                    <Border Grid.Column="1" Background="{StaticResource PanelSurface}" CornerRadius="14" Padding="14" VerticalAlignment="Center">
                        <StackPanel>
                            <TextBlock Text="{Binding Codigo}" Foreground="{StaticResource TextPrimary}" FontSize="18" FontWeight="Bold" HorizontalAlignment="Right" />
                            <TextBlock Text="{Binding StatusCadastro}" Foreground="{StaticResource AccentGold}" HorizontalAlignment="Right" Margin="0,4,0,0" />
                            <TextBlock Text="{Binding Status}" Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Right" Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.35*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="0.75*" />
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Identificação e contato" Foreground="{StaticResource TextPrimary}" FontSize="20" FontWeight="Bold" />
                        <UniformGrid Columns="2" Margin="0,14,0,0">
                            <StackPanel Margin="0,0,12,12">
                                <TextBlock Text="Tipo de cadastro" Foreground="{StaticResource TextSecondary}" />
                                <ComboBox ItemsSource="{Binding CadastroTypes}" SelectedItem="{Binding TipoCadastro}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="Nome / razão social / descrição" Foreground="{StaticResource TextSecondary}" />
                                <TextBox Text="{Binding NomeRazaoSocial, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,12,12">
                                <TextBlock Text="CPF/CNPJ/código fiscal" Foreground="{StaticResource TextSecondary}" />
                                <TextBox Text="{Binding DocumentoFiscal, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="Inscrição estadual/municipal" Foreground="{StaticResource TextSecondary}" />
                                <TextBox Text="{Binding InscricaoEstadualMunicipal, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,12,12">
                                <TextBlock Text="E-mail" Foreground="{StaticResource TextSecondary}" />
                                <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="Telefone / WhatsApp" Foreground="{StaticResource TextSecondary}" />
                                <TextBox Text="{Binding Telefone, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,12,12">
                                <TextBlock Text="CEP" Foreground="{StaticResource TextSecondary}" />
                                <TextBox Text="{Binding Cep, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="Endereço completo" Foreground="{StaticResource TextSecondary}" />
                                <TextBox Text="{Binding EnderecoCompleto, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </UniformGrid>

                        <TextBlock Text="Fiscal, contábil e comercial" Foreground="{StaticResource TextPrimary}" FontSize="20" FontWeight="Bold" Margin="0,12,0,0" />
                        <UniformGrid Columns="2" Margin="0,14,0,0">
                            <StackPanel Margin="0,0,12,12">
                                <TextBlock Text="Regime / regra fiscal" Foreground="{StaticResource TextSecondary}" />
                                <ComboBox ItemsSource="{Binding FiscalRegimes}" SelectedItem="{Binding RegimeFiscal}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="Conta contábil" Foreground="{StaticResource TextSecondary}" />
                                <TextBox Text="{Binding ContaContabil, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,12,12">
                                <TextBlock Text="Centro de custo" Foreground="{StaticResource TextSecondary}" />
                                <TextBox Text="{Binding CentroCusto, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="Nível de acesso" Foreground="{StaticResource TextSecondary}" />
                                <ComboBox ItemsSource="{Binding AccessLevels}" SelectedItem="{Binding NivelAcesso}" />
                            </StackPanel>
                        </UniformGrid>
                        <TextBlock Text="Regras fiscais/comerciais específicas" Foreground="{StaticResource TextSecondary}" />
                        <TextBox Text="{Binding RegrasFiscaisComerciais, UpdateSourceTrigger=PropertyChanged}" Height="80" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />

                        <TextBlock Text="Departamento pessoal / RH / folha" Foreground="{StaticResource TextPrimary}" FontSize="20" FontWeight="Bold" Margin="0,14,0,0" />
                        <UniformGrid Columns="2" Margin="0,14,0,0">
                            <StackPanel Margin="0,0,12,12">
                                <TextBlock Text="Departamento" Foreground="{StaticResource TextSecondary}" />
                                <TextBox Text="{Binding Departamento, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="Cargo / função" Foreground="{StaticResource TextSecondary}" />
                                <TextBox Text="{Binding CargoFuncao, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,12,12">
                                <TextBlock Text="Tipo de contrato" Foreground="{StaticResource TextSecondary}" />
                                <ComboBox ItemsSource="{Binding ContractTypes}" SelectedItem="{Binding TipoContrato}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="Salário base" Foreground="{StaticResource TextSecondary}" />
                                <TextBox Text="{Binding SalarioBase, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,12,12">
                                <TextBlock Text="Data admissão" Foreground="{StaticResource TextSecondary}" />
                                <DatePicker SelectedDate="{Binding DataAdmissao}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="Data desligamento" Foreground="{StaticResource TextSecondary}" />
                                <DatePicker SelectedDate="{Binding DataDesligamento}" />
                            </StackPanel>
                        </UniformGrid>

                        <TextBlock Text="Observações" Foreground="{StaticResource TextSecondary}" />
                        <TextBox Text="{Binding Observacoes, UpdateSourceTrigger=PropertyChanged}" Height="80" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Governança do cadastro" Foreground="{StaticResource TextPrimary}" FontSize="20" FontWeight="Bold" />
                        <Border Background="{StaticResource PanelSurface}" CornerRadius="14" Padding="14" Margin="0,14,0,12">
                            <StackPanel>
                                <TextBlock Text="Qualidade do registro" Foreground="{StaticResource TextSecondary}" />
                                <TextBlock Text="{Binding StatusCadastro}" Foreground="{StaticResource TextPrimary}" FontSize="24" FontWeight="Bold" TextWrapping="Wrap" />
                                <TextBlock Text="{Binding ValidacaoDetalhe}" Foreground="{StaticResource AccentGold}" TextWrapping="Wrap" FontWeight="SemiBold" Margin="0,8,0,0" />
                            </StackPanel>
                        </Border>
                        <Button Content="Salvar cadastro corporativo" Background="{StaticResource AccentGold}" Foreground="#080704" BorderThickness="0" FontWeight="Bold" Click="Salvar_Click" Margin="0,0,0,10" />
                        <Button Content="Novo cadastro" Click="Novo_Click" Margin="0,0,0,10" />
                        <Button Content="Fechar" Click="Fechar_Click" />

                        <Border Background="#0C1729" CornerRadius="14" Padding="14" Margin="0,18,0,0">
                            <TextBlock Text="{Binding Status}" Foreground="{StaticResource TextPrimary}" TextWrapping="Wrap" />
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</Window>
