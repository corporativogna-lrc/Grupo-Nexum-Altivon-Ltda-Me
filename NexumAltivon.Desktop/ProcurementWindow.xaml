<Window x:Class="NexumAltivon.Desktop.ProcurementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding WindowTitle}"
        Width="1280"
        Height="760"
        MinWidth="1100"
        MinHeight="680"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{StaticResource ShellBackground}"
        FontFamily="Segoe UI"
        Loaded="Window_Loaded">
    <Window.Resources>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBackground}" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="14" />
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>
        <Style x:Key="KpiValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="HorizontalAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource Card}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="SCM / WMS" Foreground="{StaticResource AccentGold}" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding WindowTitle}" Foreground="{StaticResource TextPrimary}" FontSize="24" FontWeight="Bold" Margin="0,3,0,0" />
                    <TextBlock Text="{Binding TenantLabel}" Foreground="{StaticResource TextSecondary}" Margin="0,4,0,0" />
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="18,0" VerticalAlignment="Center">
                    <TextBlock Text="Código" Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Right" />
                    <TextBlock Text="{Binding Codigo}" Foreground="{StaticResource TextPrimary}" FontSize="17" FontWeight="Bold" HorizontalAlignment="Right" />
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Novo" Click="Novo_Click" Margin="0,0,8,0" Padding="16,8" />
                    <Button Content="Recarregar" Click="Recarregar_Click" Padding="16,8" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="440" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource Card}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="Cabeçalho transacional" Foreground="{StaticResource TextPrimary}" FontSize="18" FontWeight="Bold" />

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0">
                            <TextBlock Text="Operação" Style="{StaticResource FieldLabel}" />
                            <ComboBox ItemsSource="{Binding OperationTypes}" SelectedItem="{Binding Tipo, Mode=TwoWay}" />
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="2">
                            <TextBlock Text="Origem" Style="{StaticResource FieldLabel}" />
                            <ComboBox ItemsSource="{Binding OrigensAquisicao}" SelectedItem="{Binding OrigemAquisicao, Mode=TwoWay}" />
                        </StackPanel>

                        <StackPanel Grid.Row="2">
                            <TextBlock Text="Produto cadastrado" Style="{StaticResource FieldLabel}" />
                            <ComboBox ItemsSource="{Binding Produtos}" SelectedItem="{Binding SelectedProduto, Mode=TwoWay}" DisplayMemberPath="ProdutoNome" />
                        </StackPanel>
                        <StackPanel Grid.Row="2" Grid.Column="2">
                            <TextBlock Text="Descrição do item" Style="{StaticResource FieldLabel}" />
                            <TextBox Text="{Binding ProdutoNome, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>

                        <StackPanel Grid.Row="4">
                            <TextBlock Text="Fornecedor" Style="{StaticResource FieldLabel}" />
                            <ComboBox ItemsSource="{Binding Fornecedores}" SelectedItem="{Binding SelectedFornecedor, Mode=TwoWay}" DisplayMemberPath="Nome" />
                        </StackPanel>
                        <StackPanel Grid.Row="4" Grid.Column="2">
                            <TextBlock Text="Solicitação vinculada" Style="{StaticResource FieldLabel}" />
                            <ComboBox ItemsSource="{Binding Solicitacoes}" SelectedItem="{Binding SelectedSolicitacao, Mode=TwoWay}" DisplayMemberPath="ProdutoNome" />
                        </StackPanel>

                        <StackPanel Grid.Row="6">
                            <TextBlock Text="Pedido para entrada" Style="{StaticResource FieldLabel}" />
                            <ComboBox ItemsSource="{Binding Pedidos}" SelectedItem="{Binding SelectedPedido, Mode=TwoWay}" DisplayMemberPath="Numero" />
                        </StackPanel>
                        <StackPanel Grid.Row="6" Grid.Column="2">
                            <TextBlock Text="Prioridade" Style="{StaticResource FieldLabel}" />
                            <ComboBox ItemsSource="{Binding Prioridades}" SelectedItem="{Binding Prioridade, Mode=TwoWay}" />
                        </StackPanel>

                        <StackPanel Grid.Row="8">
                            <TextBlock Text="Quantidade" Style="{StaticResource FieldLabel}" />
                            <TextBox Text="{Binding Quantidade, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <StackPanel Grid.Row="8" Grid.Column="2">
                            <TextBlock Text="Custo unitário" Style="{StaticResource FieldLabel}" />
                            <TextBox Text="{Binding CustoUnitario, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>

                        <StackPanel Grid.Row="10">
                            <TextBlock Text="Finalidade" Style="{StaticResource FieldLabel}" />
                            <TextBox Text="{Binding Finalidade, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <StackPanel Grid.Row="10" Grid.Column="2">
                            <TextBlock Text="Prazo entrega (dias)" Style="{StaticResource FieldLabel}" />
                            <TextBox Text="{Binding PrazoEntregaDias, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>

                        <StackPanel Grid.Row="12">
                            <TextBlock Text="Previsão de entrega" Style="{StaticResource FieldLabel}" />
                            <DatePicker SelectedDate="{Binding PrevisaoEntrega}" />
                        </StackPanel>
                        <StackPanel Grid.Row="12" Grid.Column="2">
                            <TextBlock Text="Vencimento" Style="{StaticResource FieldLabel}" />
                            <DatePicker SelectedDate="{Binding DataVencimento}" />
                        </StackPanel>

                        <StackPanel Grid.Row="14">
                            <TextBlock Text="Documento de entrada" Style="{StaticResource FieldLabel}" />
                            <TextBox Text="{Binding NumeroDocumento, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <StackPanel Grid.Row="14" Grid.Column="2">
                            <TextBlock Text="Chave NF-e de entrada" Style="{StaticResource FieldLabel}" />
                            <TextBox Text="{Binding ChaveNfeEntrada, UpdateSourceTrigger=PropertyChanged}" MaxLength="60" />
                        </StackPanel>

                        <StackPanel Grid.Row="16" Grid.ColumnSpan="3">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Meio de pagamento" Style="{StaticResource FieldLabel}" />
                                    <TextBox Text="{Binding MeioPagamento, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Recebido por" Style="{StaticResource FieldLabel}" />
                                    <TextBox Text="{Binding RecebidoPor, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </Grid>
                            <TextBlock Text="Observações" Style="{StaticResource FieldLabel}" Margin="0,8,0,4" />
                            <TextBox Text="{Binding Observacoes, UpdateSourceTrigger=PropertyChanged}" Height="52" AcceptsReturn="True" TextWrapping="Wrap" />
                        </StackPanel>
                    </Grid>

                    <Border Grid.Row="3" Background="{StaticResource PanelSurface}" CornerRadius="8" Padding="10" Margin="0,10,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Total do item" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="{Binding TotalEstimadoLabel}" Foreground="{StaticResource AccentGold}" FontSize="20" FontWeight="Bold" />
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource Card}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TabControl>
                        <TabItem Header="Solicitações">
                            <DataGrid ItemsSource="{Binding Solicitacoes}" SelectedItem="{Binding SelectedSolicitacao, Mode=TwoWay}" AutoGenerateColumns="False" IsReadOnly="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="55" />
                                    <DataGridTextColumn Header="Produto / serviço" Binding="{Binding ProdutoNome}" Width="*" />
                                    <DataGridTextColumn Header="Qtd." Binding="{Binding Quantidade}" Width="60" />
                                    <DataGridTextColumn Header="Origem" Binding="{Binding Origem}" Width="105" />
                                    <DataGridTextColumn Header="Prioridade" Binding="{Binding Prioridade}" Width="85" />
                                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="105" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>
                        <TabItem Header="Cotações">
                            <DataGrid ItemsSource="{Binding Cotacoes}" SelectedItem="{Binding SelectedCotacao, Mode=TwoWay}" AutoGenerateColumns="False" IsReadOnly="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50" />
                                    <DataGridTextColumn Header="Solic." Binding="{Binding SolicitacaoId}" Width="60" />
                                    <DataGridTextColumn Header="Fornecedor" Binding="{Binding FornecedorNome}" Width="*" />
                                    <DataGridTextColumn Header="Produto" Binding="{Binding ProdutoNome}" Width="*" />
                                    <DataGridTextColumn Header="Qtd." Binding="{Binding Quantidade}" Width="55" />
                                    <DataGridTextColumn Header="Total" Binding="{Binding ValorTotal, StringFormat=N2}" Width="90" />
                                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="85" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>
                        <TabItem Header="Pedidos">
                            <DataGrid ItemsSource="{Binding Pedidos}" SelectedItem="{Binding SelectedPedido, Mode=TwoWay}" AutoGenerateColumns="False" IsReadOnly="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Número" Binding="{Binding Numero}" Width="145" />
                                    <DataGridTextColumn Header="Fornecedor" Binding="{Binding FornecedorNome}" Width="*" />
                                    <DataGridTextColumn Header="Total" Binding="{Binding ValorTotal, StringFormat=N2}" Width="90" />
                                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="105" />
                                    <DataGridTextColumn Header="Fiscal" Binding="{Binding StatusFiscal}" Width="110" />
                                    <DataGridTextColumn Header="Previsão" Binding="{Binding DataPrevistaEntrega, StringFormat=dd/MM/yyyy}" Width="90" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>
                        <TabItem Header="Entradas / estoque">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="8" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <DataGrid ItemsSource="{Binding ItensEntrada}" AutoGenerateColumns="False" CanUserAddRows="False">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Item" Binding="{Binding ItemId}" IsReadOnly="True" Width="55" />
                                        <DataGridTextColumn Header="Produto" Binding="{Binding ProdutoNome}" IsReadOnly="True" Width="*" />
                                        <DataGridTextColumn Header="Pedido" Binding="{Binding QuantidadePedido}" IsReadOnly="True" Width="65" />
                                        <DataGridTextColumn Header="Já recebido" Binding="{Binding QuantidadeRecebida}" IsReadOnly="True" Width="85" />
                                        <DataGridTextColumn Header="Pendente" Binding="{Binding QuantidadePendente}" IsReadOnly="True" Width="70" />
                                        <DataGridTextColumn Header="Receber agora" Binding="{Binding QuantidadeReceber, UpdateSourceTrigger=PropertyChanged}" Width="95" />
                                    </DataGrid.Columns>
                                </DataGrid>
                                <DataGrid Grid.Row="2" ItemsSource="{Binding Entradas}" SelectedItem="{Binding SelectedEntrada, Mode=TwoWay}" AutoGenerateColumns="False" IsReadOnly="True">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Entrada" Binding="{Binding Id}" Width="60" />
                                        <DataGridTextColumn Header="Pedido" Binding="{Binding PedidoNumero}" Width="135" />
                                        <DataGridTextColumn Header="Fornecedor" Binding="{Binding FornecedorNome}" Width="*" />
                                        <DataGridTextColumn Header="Documento" Binding="{Binding NumeroDocumento}" Width="100" />
                                        <DataGridTextColumn Header="Valor" Binding="{Binding ValorTotal, StringFormat=N2}" Width="85" />
                                        <DataGridTextColumn Header="Fiscal" Binding="{Binding StatusFiscal}" Width="115" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </TabItem>
                    </TabControl>
                    <TextBlock Grid.Row="1" Text="{Binding AlertasTexto}" Foreground="{StaticResource AccentGold}" TextWrapping="Wrap" Margin="2,10,2,0" />
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="4" Style="{StaticResource Card}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="18" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <UniformGrid Columns="4" Width="360">
                    <StackPanel>
                        <TextBlock Text="Solicitações" Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center" />
                        <TextBlock Text="{Binding KpiSolicitacoes}" Style="{StaticResource KpiValue}" />
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="Pedidos" Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center" />
                        <TextBlock Text="{Binding KpiPedidos}" Style="{StaticResource KpiValue}" />
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="Entradas/mês" Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center" />
                        <TextBlock Text="{Binding KpiEntradas}" Style="{StaticResource KpiValue}" />
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="Em aberto" Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center" />
                        <TextBlock Text="{Binding KpiValor}" Style="{StaticResource KpiValue}" FontSize="14" />
                    </StackPanel>
                </UniformGrid>

                <Border Grid.Column="2" Background="{StaticResource PanelSurface}" CornerRadius="8" Padding="10,7">
                    <TextBlock Text="{Binding Status}" Foreground="{StaticResource TextPrimary}" TextWrapping="Wrap" VerticalAlignment="Center" />
                </Border>

                <StackPanel Grid.Row="2" Grid.ColumnSpan="3" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Content="Salvar" Click="Salvar_Click" Background="{StaticResource AccentGold}" Foreground="#080704" FontWeight="Bold" Padding="15,8" Margin="0,0,6,0" />
                    <Button Content="Enviar" Click="EnviarAprovacao_Click" Padding="12,8" Margin="0,0,6,0" />
                    <Button Content="Aprovar" Click="Aprovar_Click" Padding="12,8" Margin="0,0,6,0" />
                    <Button Content="Reprovar" Click="Reprovar_Click" Padding="12,8" Margin="0,0,6,0" />
                    <Button Content="Gerar pedido" Click="GerarPedido_Click" Padding="12,8" Margin="0,0,6,0" />
                    <Button Content="Registrar entrada" Click="RegistrarEntrada_Click" Padding="12,8" Margin="0,0,6,0" />
                    <Button Content="Fechar" Click="Fechar_Click" Padding="12,8" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
