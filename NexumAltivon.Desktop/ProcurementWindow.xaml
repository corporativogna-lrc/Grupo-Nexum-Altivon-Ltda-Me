<Window x:Class="NexumAltivon.Desktop.ProcurementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding WindowTitle}"
        Width="1180"
        Height="720"
        MinWidth="980"
        MinHeight="640"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="{StaticResource ShellBackground}"
        FontFamily="Segoe UI">
    <Window.Resources>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBackground}" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Padding" Value="18" />
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
        <Grid Margin="18" MinWidth="940">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="16" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Style="{StaticResource Card}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="SCM / WMS" Foreground="{StaticResource AccentGold}" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding WindowTitle}" Foreground="{StaticResource TextPrimary}" FontSize="30" FontWeight="Bold" Margin="0,6,0,0" />
                        <TextBlock Text="Ciclo aquisitivo local: solicitação, cotação, pedido, entrada, origem, custo, estoque físico/fiscal, código de barras e QR Code." Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" Margin="0,8,0,0" MaxWidth="760" />
                    </StackPanel>
                    <Border Grid.Column="1" Background="{StaticResource PanelSurface}" CornerRadius="14" Padding="14" VerticalAlignment="Center">
                        <StackPanel>
                            <TextBlock Text="{Binding Codigo}" Foreground="{StaticResource TextPrimary}" FontSize="18" FontWeight="Bold" HorizontalAlignment="Right" />
                            <TextBlock Text="Compra local" Foreground="{StaticResource AccentGreen}" HorizontalAlignment="Right" Margin="0,4,0,0" />
                            <TextBlock Text="{Binding Status}" Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Right" Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="0.8*" />
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Dados da aquisição" Foreground="{StaticResource TextPrimary}" FontSize="20" FontWeight="Bold" />
                        <UniformGrid Columns="2" Margin="0,14,0,0">
                            <StackPanel Margin="0,0,12,12">
                                <TextBlock Text="Tipo" Foreground="{StaticResource TextSecondary}" />
                                <ComboBox ItemsSource="{Binding OperationTypes}" SelectedItem="{Binding Tipo}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="Empresa destino" Foreground="{StaticResource TextSecondary}" />
                                <ComboBox ItemsSource="{Binding EmpresasDestino}" SelectedItem="{Binding EmpresaDestino}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,12,12">
                                <TextBlock Text="Origem aquisição" Foreground="{StaticResource TextSecondary}" />
                                <ComboBox ItemsSource="{Binding OrigensAquisicao}" SelectedItem="{Binding OrigemAquisicao}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="Fornecedor / parceiro" Foreground="{StaticResource TextSecondary}" />
                                <TextBox Text="{Binding FornecedorParceiro, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,12,12">
                                <TextBlock Text="Item / descrição" Foreground="{StaticResource TextSecondary}" />
                                <TextBox Text="{Binding ItemDescricao, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="Categoria" Foreground="{StaticResource TextSecondary}" />
                                <TextBox Text="{Binding Categoria, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,12,12">
                                <TextBlock Text="Quantidade" Foreground="{StaticResource TextSecondary}" />
                                <TextBox Text="{Binding Quantidade, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="Custo unitário" Foreground="{StaticResource TextSecondary}" />
                                <TextBox Text="{Binding CustoUnitario, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,12,12">
                                <TextBlock Text="Frete estimado" Foreground="{StaticResource TextSecondary}" />
                                <TextBox Text="{Binding FreteEstimado, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="Impostos estimados" Foreground="{StaticResource TextSecondary}" />
                                <TextBox Text="{Binding ImpostosEstimados, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,12,12">
                                <TextBlock Text="Nível de aprovação" Foreground="{StaticResource TextSecondary}" />
                                <ComboBox ItemsSource="{Binding NiveisAprovacao}" SelectedItem="{Binding NivelAprovacao}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="Aprovador responsável" Foreground="{StaticResource TextSecondary}" />
                                <TextBox Text="{Binding AprovadorResponsavel, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,12,12">
                                <TextBlock Text="Status do fluxo" Foreground="{StaticResource TextSecondary}" />
                                <ComboBox ItemsSource="{Binding StatusAprovacaoOptions}" SelectedItem="{Binding StatusAprovacao}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="Condição de pagamento" Foreground="{StaticResource TextSecondary}" />
                                <TextBox Text="{Binding CondicaoPagamento, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </UniformGrid>

                        <TextBlock Text="Centro de custo" Foreground="{StaticResource TextSecondary}" Margin="0,6,0,5" />
                        <TextBox Text="{Binding CentroCusto, UpdateSourceTrigger=PropertyChanged}" />
                        <Border Background="{StaticResource PanelSurface}" CornerRadius="12" Padding="12" Margin="0,12,0,0">
                            <StackPanel>
                                <TextBlock Text="Cadastro fiscal e comercial do produto" Foreground="{StaticResource TextPrimary}" FontWeight="Bold" />
                                <TextBlock Text="{Binding StatusCadastroProduto}" Foreground="{StaticResource AccentGold}" TextWrapping="Wrap" Margin="0,6,0,10" />
                                <UniformGrid Columns="2">
                                    <StackPanel Margin="0,0,12,10">
                                        <TextBlock Text="Unidade comercial" Foreground="{StaticResource TextSecondary}" />
                                        <TextBox Text="{Binding UnidadeComercial, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,0,10">
                                        <TextBlock Text="NCM" Foreground="{StaticResource TextSecondary}" />
                                        <TextBox Text="{Binding Ncm, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,12,10">
                                        <TextBlock Text="CEST" Foreground="{StaticResource TextSecondary}" />
                                        <TextBox Text="{Binding Cest, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,0,10">
                                        <TextBlock Text="CFOP sugerido" Foreground="{StaticResource TextSecondary}" />
                                        <TextBox Text="{Binding CfopSugerido, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,12,10">
                                        <TextBlock Text="Origem fiscal" Foreground="{StaticResource TextSecondary}" />
                                        <ComboBox ItemsSource="{Binding OrigensFiscais}" SelectedItem="{Binding OrigemFiscalItem}" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,0,10">
                                        <TextBlock Text="GTIN / código de barras" Foreground="{StaticResource TextSecondary}" />
                                        <TextBox Text="{Binding GtinCodigoBarras, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                </UniformGrid>
                                <TextBlock Text="Peso / dimensões / embalagem" Foreground="{StaticResource TextSecondary}" />
                                <TextBox Text="{Binding PesoDimensoes, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </Border>
                        <Border Background="{StaticResource PanelSurface}" CornerRadius="12" Padding="12" Margin="0,12,0,0">
                            <StackPanel>
                                <TextBlock Text="Entrada por XML de NF-e" Foreground="{StaticResource TextPrimary}" FontWeight="Bold" />
                                <TextBlock Text="{Binding XmlResumo}" Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" Margin="0,6,0,10" />
                                <Button Content="Importar XML da NF-e" Click="ImportarXml_Click" HorizontalAlignment="Left" Padding="18,8" />
                            </StackPanel>
                        </Border>
                        <Border Background="{StaticResource PanelSurface}" CornerRadius="12" Padding="12" Margin="0,12,0,0">
                            <StackPanel>
                                <TextBlock Text="Documento, entrada e entrega" Foreground="{StaticResource TextPrimary}" FontWeight="Bold" />
                                <UniformGrid Columns="2" Margin="0,10,0,0">
                                    <StackPanel Margin="0,0,12,10">
                                        <TextBlock Text="Número NF / documento" Foreground="{StaticResource TextSecondary}" />
                                        <TextBox Text="{Binding NumeroDocumentoFornecedor, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,0,10">
                                        <TextBlock Text="Série" Foreground="{StaticResource TextSecondary}" />
                                        <TextBox Text="{Binding SerieDocumentoFornecedor, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,12,10">
                                        <TextBlock Text="Emissão" Foreground="{StaticResource TextSecondary}" />
                                        <DatePicker SelectedDate="{Binding DataEmissaoDocumento}" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,0,10">
                                        <TextBlock Text="Entrada" Foreground="{StaticResource TextSecondary}" />
                                        <DatePicker SelectedDate="{Binding DataEntradaMercadoria}" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,12,10">
                                        <TextBlock Text="Previsão entrega" Foreground="{StaticResource TextSecondary}" />
                                        <DatePicker SelectedDate="{Binding PrevisaoEntrega}" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,0,10">
                                        <TextBlock Text="Etapa operacional" Foreground="{StaticResource TextSecondary}" />
                                        <TextBlock Text="{Binding EtapaOperacional}" Foreground="{StaticResource AccentGold}" TextWrapping="Wrap" />
                                    </StackPanel>
                                </UniformGrid>
                            </StackPanel>
                        </Border>
                        <TextBlock Text="Observações" Foreground="{StaticResource TextSecondary}" Margin="0,10,0,5" />
                        <TextBox Text="{Binding Observacoes, UpdateSourceTrigger=PropertyChanged}" Height="100" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Resumo de custo e estoque" Foreground="{StaticResource TextPrimary}" FontSize="20" FontWeight="Bold" />
                        <Border Background="{StaticResource PanelSurface}" CornerRadius="14" Padding="14" Margin="0,14,0,12">
                            <StackPanel>
                                <TextBlock Text="Total estimado" Foreground="{StaticResource TextSecondary}" />
                                <TextBlock Text="{Binding TotalEstimadoLabel}" Foreground="{StaticResource TextPrimary}" FontSize="28" FontWeight="Bold" />
                                <TextBlock Text="{Binding CodigoProdutoSugerido}" Foreground="{StaticResource AccentGold}" TextWrapping="Wrap" FontWeight="SemiBold" Margin="0,8,0,0" />
                                <TextBlock Text="{Binding FluxoAprovacao}" Foreground="{StaticResource AccentGold}" TextWrapping="Wrap" FontWeight="SemiBold" Margin="0,8,0,0" />
                                <TextBlock Text="{Binding ControleEntrada}" Foreground="{StaticResource AccentGreen}" TextWrapping="Wrap" FontWeight="SemiBold" Margin="0,8,0,0" />
                            </StackPanel>
                        </Border>
                        <Button Content="Salvar aquisição local" Background="{StaticResource AccentGold}" Foreground="#080704" BorderThickness="0" FontWeight="Bold" Click="Salvar_Click" Margin="0,0,0,10" />
                        <Button Content="Enviar para aprovação" Click="EnviarAprovacao_Click" Margin="0,0,0,10" />
                        <Button Content="Aprovar" Click="Aprovar_Click" Margin="0,0,0,10" />
                        <Button Content="Reprovar" Click="Reprovar_Click" Margin="0,0,0,10" />
                        <Button Content="Gerar pedido" Click="GerarPedido_Click" Margin="0,0,0,10" />
                        <Button Content="Registrar entrada no estoque" Click="RegistrarEntrada_Click" Margin="0,0,0,10" />
                        <Button Content="Novo documento" Click="Novo_Click" Margin="0,0,0,10" />
                        <Button Content="Fechar" Click="Fechar_Click" />

                        <Border Background="#0C1729" CornerRadius="14" Padding="14" Margin="0,18,0,0">
                            <TextBlock Text="{Binding Status}" Foreground="{StaticResource TextPrimary}" TextWrapping="Wrap" />
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</Window>
