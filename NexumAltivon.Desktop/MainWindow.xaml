<Window x:Class="NexumAltivon.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:NexumAltivon.Desktop.Models"
        mc:Ignorable="d"
        Title="GenesisGest Desktop"
        Width="1480"
        Height="920"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource ShellBackground}"
        FontFamily="Segoe UI">
    <Window.Resources>
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="CornerRadius" Value="20" />
            <Setter Property="Background" Value="{StaticResource PanelBackground}" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="20" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>
        <Style x:Key="MetricValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="FontSize" Value="28" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>
        <Style x:Key="MetricLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,4,0,0" />
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Padding" Value="16,10" />
            <Setter Property="Background" Value="{StaticResource AccentBlue}" />
            <Setter Property="Foreground" Value="#08111F" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Padding" Value="16,10" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="330" />
            <ColumnDefinition Width="22" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Style="{StaticResource CardBorder}">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,18">
                    <TextBlock Text="Grupo Nexum Altivon" Foreground="{StaticResource AccentBlue}" FontWeight="SemiBold" />
                    <TextBlock Text="GenesisGest Desktop" Foreground="{StaticResource TextPrimary}" FontSize="26" FontWeight="Bold" Margin="0,6,0,0" />
                    <TextBlock Text="Operacao local, visual executivo e controle corporativo para a empresa." Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" Margin="0,8,0,0" />
                </StackPanel>

                <StackPanel>
                    <Border Background="#0C1729" CornerRadius="16" Padding="16" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Status do ambiente" Foreground="{StaticResource TextSecondary}" FontSize="12" />
                            <TextBlock Text="{Binding EnvironmentStatus}" Foreground="{StaticResource TextPrimary}" FontSize="18" FontWeight="Bold" Margin="0,4,0,0" />
                            <TextBlock Text="{Binding EnvironmentDetail}" Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" Margin="0,6,0,0" />
                        </StackPanel>
                    </Border>

                    <Border Background="#0C1729" CornerRadius="16" Padding="16" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Presenca corporativa" Foreground="{StaticResource TextSecondary}" FontSize="12" />
                            <TextBlock Text="Visual de multinacional" Foreground="{StaticResource TextPrimary}" FontSize="18" FontWeight="Bold" Margin="0,4,0,0" />
                            <TextBlock Text="Painel preparado para financeiro, fiscal, estoque, CRM, compras e diretorio local." Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" Margin="0,6,0,0" />
                        </StackPanel>
                    </Border>

                    <Border Background="#0C1729" CornerRadius="16" Padding="16" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Pronto para a operacao" Foreground="{StaticResource TextSecondary}" FontSize="12" />
                            <TextBlock Text="{Binding SelectedModuleTitle}" Foreground="{StaticResource TextPrimary}" FontSize="18" FontWeight="Bold" Margin="0,4,0,0" />
                            <TextBlock Text="{Binding SelectedModuleDetail}" Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" Margin="0,6,0,0" />
                        </StackPanel>
                    </Border>

                    <StackPanel Orientation="Horizontal">
                        <Button Content="Abrir portal" Style="{StaticResource PrimaryButton}" Click="OpenPortal_Click" Margin="0,0,10,0" />
                        <Button Content="Atualizar status" Style="{StaticResource GhostButton}" Click="RefreshStatus_Click" />
                        <Button Content="Emissão manual" Style="{StaticResource GhostButton}" Click="OpenManualNfe_Click" Margin="10,0,0,0" />
                    </StackPanel>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="18" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="18" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Style="{StaticResource CardBorder}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Painel executivo local" Foreground="{StaticResource AccentBlue}" FontWeight="SemiBold" />
                        <TextBlock Text="Controle a empresa sem perder a visao do grupo inteiro." Foreground="{StaticResource TextPrimary}" FontSize="30" FontWeight="Bold" Margin="0,8,0,0" />
                        <TextBlock Text="O desktop nasce para a gestao interna da empresa, enquanto vendas, clientes e integracoes seguem conectados a API e ao ERP." Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" Margin="0,10,0,0" MaxWidth="780" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <TextBlock Text="{Binding LastUpdatedLabel}" Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Right" />
                        <Border Background="#0C1729" CornerRadius="14" Padding="14" Margin="0,10,0,0">
                            <StackPanel>
                                <TextBlock Text="Pronto para ampliar" Foreground="{StaticResource AccentGreen}" FontWeight="SemiBold" />
                                <TextBlock Text="ERP + Desktop + Vendas" Foreground="{StaticResource TextPrimary}" FontSize="18" FontWeight="Bold" Margin="0,4,0,0" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <UniformGrid Grid.Row="2" Columns="4" Rows="1" Margin="0,0,0,0">
                <Border Style="{StaticResource CardBorder}" Margin="0,0,14,0">
                    <StackPanel>
                        <TextBlock Text="{Binding SalesMetricValue}" Style="{StaticResource MetricValue}" />
                        <TextBlock Text="Venda imediata" Style="{StaticResource MetricLabel}" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardBorder}" Margin="0,0,14,0">
                    <StackPanel>
                        <TextBlock Text="{Binding FiscalMetricValue}" Style="{StaticResource MetricValue}" />
                        <TextBlock Text="Fiscal e NF" Style="{StaticResource MetricLabel}" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardBorder}" Margin="0,0,14,0">
                    <StackPanel>
                        <TextBlock Text="{Binding GroupMetricValue}" Style="{StaticResource MetricValue}" />
                        <TextBlock Text="Empresas do grupo" Style="{StaticResource MetricLabel}" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Text="{Binding IntegrationMetricValue}" Style="{StaticResource MetricValue}" />
                        <TextBlock Text="Integrações aguardando chave" Style="{StaticResource MetricLabel}" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.4*" />
                    <ColumnDefinition Width="18" />
                    <ColumnDefinition Width="0.9*" />
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource CardBorder}">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="Módulos do desktop" Foreground="{StaticResource TextPrimary}" FontSize="18" FontWeight="Bold" Margin="0,0,0,14" />
                        <ItemsControl ItemsSource="{Binding Modules}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="2" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Click="ModuleCard_Click" Tag="{Binding}" Background="#0C1729" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1" Padding="16" Margin="0,0,12,12" Cursor="Hand">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="16" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter />
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <Border Width="12" Height="12" CornerRadius="6" Background="{Binding Accent}" Margin="0,0,10,0" />
                                                <TextBlock Text="{Binding Title}" Foreground="{StaticResource TextPrimary}" FontSize="16" FontWeight="SemiBold" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding Detail}" Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" Margin="0,10,0,0" />
                                            <TextBlock Text="{Binding Status}" Foreground="{StaticResource AccentGreen}" FontSize="12" FontWeight="SemiBold" Margin="0,12,0,0" />
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </DockPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource CardBorder}">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="Estrutura organizacional" Foreground="{StaticResource TextPrimary}" FontSize="18" FontWeight="Bold" />
                        <TextBlock DockPanel.Dock="Top" Text="Holding, filiais e parceiros com padrao de 5 caixas de e-mail por dominio." Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" Margin="0,8,0,14" />
                        <TreeView ItemsSource="{Binding OrganizationUnits}" Background="Transparent" BorderThickness="0">
                            <TreeView.Resources>
                                <HierarchicalDataTemplate DataType="{x:Type models:OrganizationNode}" ItemsSource="{Binding Children}">
                                    <Border Background="#0C1729" CornerRadius="14" Padding="12" Margin="0,0,0,10" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextPrimary}" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding Role}" Foreground="{StaticResource AccentBlue}" FontSize="12" Margin="0,4,0,0" />
                                            <TextBlock Text="{Binding TaxSituation}" Foreground="{StaticResource AccentAmber}" FontSize="12" Margin="0,4,0,0" />
                                            <TextBlock Text="{Binding Domain}" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,4,0,0" />
                                            <TextBlock Text="{Binding EmailPattern}" Foreground="{StaticResource TextSecondary}" FontSize="12" TextWrapping="Wrap" Margin="0,4,0,0" />
                                        </StackPanel>
                                    </Border>
                                </HierarchicalDataTemplate>
                            </TreeView.Resources>
                        </TreeView>
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
