<Window x:Class="NexumAltivon.Desktop.FinancialLedgerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding WindowTitle}"
        Width="1180"
        Height="720"
        MinWidth="980"
        MinHeight="640"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="{StaticResource ShellBackground}"
        FontFamily="Segoe UI">
    <Window.Resources>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBackground}" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Padding" Value="18" />
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
        <Grid Margin="18" MinWidth="940">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="16" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Style="{StaticResource Card}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="FICO / FINANCEIRO" Foreground="{StaticResource AccentGold}" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding WindowTitle}" Foreground="{StaticResource TextPrimary}" FontSize="30" FontWeight="Bold" Margin="0,6,0,0" />
                        <TextBlock Text="Registro local financeiro com empresa, pessoa, documento, vencimento, valores, centro de custo, alçada e observação operacional." Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" Margin="0,8,0,0" MaxWidth="760" />
                    </StackPanel>
                    <Border Grid.Column="1" Background="{StaticResource PanelSurface}" CornerRadius="14" Padding="14" VerticalAlignment="Center">
                        <StackPanel>
                            <TextBlock Text="{Binding Codigo}" Foreground="{StaticResource TextPrimary}" FontSize="18" FontWeight="Bold" HorizontalAlignment="Right" />
                            <TextBlock Text="Documento local" Foreground="{StaticResource AccentGreen}" HorizontalAlignment="Right" Margin="0,4,0,0" />
                            <TextBlock Text="{Binding Status}" Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Right" Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="0.8*" />
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Dados do lançamento" Foreground="{StaticResource TextPrimary}" FontSize="20" FontWeight="Bold" />
                        <UniformGrid Columns="2" Margin="0,14,0,0">
                            <StackPanel Margin="0,0,12,12">
                                <TextBlock Text="Tipo" Foreground="{StaticResource TextSecondary}" />
                                <ComboBox ItemsSource="{Binding DocumentTypes}" SelectedItem="{Binding Tipo}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="Empresa" Foreground="{StaticResource TextSecondary}" />
                                <TextBox Text="{Binding Empresa, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,12,12">
                                <TextBlock Text="Cliente / fornecedor" Foreground="{StaticResource TextSecondary}" />
                                <TextBox Text="{Binding Pessoa, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="Documento" Foreground="{StaticResource TextSecondary}" />
                                <TextBox Text="{Binding Documento, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,12,12">
                                <TextBlock Text="Centro de custo" Foreground="{StaticResource TextSecondary}" />
                                <TextBox Text="{Binding CentroCusto, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="Conta financeira" Foreground="{StaticResource TextSecondary}" />
                                <TextBox Text="{Binding ContaFinanceira, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,12,12">
                                <TextBlock Text="Valor" Foreground="{StaticResource TextSecondary}" />
                                <TextBox Text="{Binding Valor, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="Vencimento" Foreground="{StaticResource TextSecondary}" />
                                <DatePicker SelectedDate="{Binding Vencimento}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,12,12">
                                <TextBlock Text="Desconto" Foreground="{StaticResource TextSecondary}" />
                                <TextBox Text="{Binding Desconto, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="Juros / multa" Foreground="{StaticResource TextSecondary}" />
                                <TextBox Text="{Binding JurosMulta, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </UniformGrid>

                        <TextBlock Text="Aprovação / alçada" Foreground="{StaticResource TextSecondary}" Margin="0,6,0,5" />
                        <TextBox Text="{Binding Aprovacao, UpdateSourceTrigger=PropertyChanged}" />
                        <UniformGrid Columns="2" Margin="0,10,0,0">
                            <StackPanel Margin="0,0,12,10">
                                <TextBlock Text="Nível de alçada" Foreground="{StaticResource TextSecondary}" />
                                <ComboBox ItemsSource="{Binding ApprovalLevels}" SelectedItem="{Binding NivelAlcada}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,0,10">
                                <TextBlock Text="Aprovador responsável" Foreground="{StaticResource TextSecondary}" />
                                <TextBox Text="{Binding AprovadorResponsavel, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </UniformGrid>
                        <CheckBox Content="Bloquear pagamento enquanto não houver aprovação" IsChecked="{Binding BloquearPagamentoSemAprovacao}" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,6" />
                        <TextBlock Text="Observações" Foreground="{StaticResource TextSecondary}" Margin="0,10,0,5" />
                        <TextBox Text="{Binding Observacoes, UpdateSourceTrigger=PropertyChanged}" Height="100" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Resumo e controle" Foreground="{StaticResource TextPrimary}" FontSize="20" FontWeight="Bold" />
                        <Border Background="{StaticResource PanelSurface}" CornerRadius="14" Padding="14" Margin="0,14,0,12">
                            <StackPanel>
                                <TextBlock Text="Total líquido" Foreground="{StaticResource TextSecondary}" />
                                <TextBlock Text="{Binding TotalLiquidoLabel}" Foreground="{StaticResource TextPrimary}" FontSize="28" FontWeight="Bold" />
                                <TextBlock Text="{Binding IndicadorAlcada}" Foreground="{StaticResource AccentGold}" TextWrapping="Wrap" FontWeight="SemiBold" Margin="0,8,0,0" />
                                <TextBlock Text="{Binding StatusPagamento}" Foreground="{StaticResource AccentGreen}" TextWrapping="Wrap" FontWeight="SemiBold" Margin="0,8,0,0" />
                            </StackPanel>
                        </Border>
                        <Button Content="Salvar lançamento local" Background="{StaticResource AccentGold}" Foreground="#080704" BorderThickness="0" FontWeight="Bold" Click="Salvar_Click" Margin="0,0,0,10" />
                        <Button Content="Novo lançamento" Click="Novo_Click" Margin="0,0,0,10" />
                        <Button Content="Fechar" Click="Fechar_Click" />

                        <Border Background="#0C1729" CornerRadius="14" Padding="14" Margin="0,18,0,0">
                            <TextBlock Text="{Binding Status}" Foreground="{StaticResource TextPrimary}" TextWrapping="Wrap" />
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</Window>
