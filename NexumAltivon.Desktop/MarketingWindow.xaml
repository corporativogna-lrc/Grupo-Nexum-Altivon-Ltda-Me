<Window x:Class="NexumAltivon.Desktop.MarketingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GenesisGest.Net - Marketing e CRM"
        Width="1280" Height="800" MinWidth="1080" MinHeight="680"
        WindowStartupLocation="CenterOwner" Background="{StaticResource ShellBackground}"
        FontFamily="Segoe UI">
    <Window.Resources>
        <Style x:Key="Panel" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBackground}" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="18" />
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
            <Setter Property="Margin" Value="0,0,0,5" />
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource Panel}">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="COMERCIAL / CRM" Foreground="{StaticResource AccentGold}" FontWeight="Bold" />
                    <TextBlock Text="Marketing operacional" Foreground="{StaticResource TextPrimary}" FontSize="28" FontWeight="Bold" Margin="0,5,0,0" />
                    <TextBlock Text="Campanhas, segmentos, investimento e resultados gravados pela API oficial." Foreground="{StaticResource TextSecondary}" Margin="0,6,0,0" />
                </StackPanel>
                <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                    <TextBlock Text="{Binding SessionLabel}" Foreground="{StaticResource TextPrimary}" FontWeight="Bold" HorizontalAlignment="Right" />
                    <TextBlock Text="{Binding EndpointLabel}" Foreground="{StaticResource AccentGreen}" Margin="0,5,0,0" HorizontalAlignment="Right" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource Panel}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" /><ColumnDefinition Width="12" /><ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="12" /><ColumnDefinition Width="1.2*" /><ColumnDefinition Width="12" /><ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel><TextBlock Text="E-mail administrativo" Style="{StaticResource FieldLabel}" /><TextBox Text="{Binding LoginEmail, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
                <StackPanel Grid.Column="2"><TextBlock Text="Senha" Style="{StaticResource FieldLabel}" /><PasswordBox x:Name="LoginPassword" /></StackPanel>
                <StackPanel Grid.Column="4"><TextBlock Text="MFA (quando ativo)" Style="{StaticResource FieldLabel}" /><TextBox Text="{Binding MfaCode, UpdateSourceTrigger=PropertyChanged}" MaxLength="8" /></StackPanel>
                <Button Grid.Column="6" Content="Autenticar" Click="Authenticate_Click" Padding="22,10" VerticalAlignment="Bottom" />
            </Grid>
        </Border>

        <TabControl x:Name="MainTabs" Grid.Row="4" IsEnabled="{Binding IsAuthenticated}">
            <TabItem Header="Campanhas">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="0.95*" /><ColumnDefinition Width="12" /><ColumnDefinition Width="1.05*" /></Grid.ColumnDefinitions>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <Border Style="{StaticResource Panel}">
                            <StackPanel>
                                <DockPanel><TextBlock Text="Cadastro de campanha" Foreground="{StaticResource TextPrimary}" FontSize="19" FontWeight="Bold" /><Button Content="Nova" Click="NewCampaign_Click" DockPanel.Dock="Right" Padding="14,6" /></DockPanel>
                                <UniformGrid Columns="2" Margin="0,14,0,0">
                                    <StackPanel Margin="0,0,10,10"><TextBlock Text="Nome" Style="{StaticResource FieldLabel}" /><TextBox Text="{Binding CampaignName, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
                                    <StackPanel Margin="0,0,0,10"><TextBlock Text="Tipo" Style="{StaticResource FieldLabel}" /><ComboBox ItemsSource="{Binding CampaignTypes}" SelectedItem="{Binding CampaignType}" /></StackPanel>
                                    <StackPanel Margin="0,0,10,10"><TextBlock Text="Status" Style="{StaticResource FieldLabel}" /><ComboBox ItemsSource="{Binding AllowedCampaignStatuses}" SelectedItem="{Binding CampaignStatus}" /></StackPanel>
                                    <StackPanel Margin="0,0,0,10"><TextBlock Text="Segmento" Style="{StaticResource FieldLabel}" /><ComboBox ItemsSource="{Binding Segments}" DisplayMemberPath="Nome" SelectedValuePath="Id" SelectedValue="{Binding CampaignSegmentId}" /></StackPanel>
                                    <StackPanel Margin="0,0,10,10"><TextBlock Text="Início" Style="{StaticResource FieldLabel}" /><DatePicker SelectedDate="{Binding CampaignStart}" /></StackPanel>
                                    <StackPanel Margin="0,0,0,10"><TextBlock Text="Término" Style="{StaticResource FieldLabel}" /><DatePicker SelectedDate="{Binding CampaignEnd}" /></StackPanel>
                                    <StackPanel Margin="0,0,10,10"><TextBlock Text="Orçamento" Style="{StaticResource FieldLabel}" /><TextBox Text="{Binding CampaignBudget, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
                                    <StackPanel Margin="0,0,0,10"><TextBlock Text="Custo realizado" Style="{StaticResource FieldLabel}" /><TextBox Text="{Binding CampaignCost, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
                                    <StackPanel Margin="0,0,10,10"><TextBlock Text="Alcance" Style="{StaticResource FieldLabel}" /><TextBox Text="{Binding CampaignReach, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
                                    <StackPanel Margin="0,0,0,10"><TextBlock Text="Cliques" Style="{StaticResource FieldLabel}" /><TextBox Text="{Binding CampaignClicks, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
                                    <StackPanel Margin="0,0,10,10"><TextBlock Text="Leads" Style="{StaticResource FieldLabel}" /><TextBox Text="{Binding CampaignLeads, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
                                    <StackPanel Margin="0,0,0,10"><TextBlock Text="Oportunidades" Style="{StaticResource FieldLabel}" /><TextBox Text="{Binding CampaignOpportunities, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
                                    <StackPanel Margin="0,0,10,10"><TextBlock Text="Vendas" Style="{StaticResource FieldLabel}" /><TextBox Text="{Binding CampaignSales, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
                                    <StackPanel Margin="0,0,0,10"><TextBlock Text="Receita" Style="{StaticResource FieldLabel}" /><TextBox Text="{Binding CampaignRevenue, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
                                </UniformGrid>
                                <TextBlock Text="Descrição" Style="{StaticResource FieldLabel}" /><TextBox Text="{Binding CampaignDescription, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" Height="55" TextWrapping="Wrap" />
                                <TextBlock Text="Público-alvo" Style="{StaticResource FieldLabel}" Margin="0,10,0,5" /><TextBox Text="{Binding CampaignAudience, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="Conteúdo" Style="{StaticResource FieldLabel}" Margin="0,10,0,5" /><TextBox Text="{Binding CampaignContent, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" Height="55" TextWrapping="Wrap" />
                                <Button Content="Salvar campanha" Click="SaveCampaign_Click" Padding="18,10" HorizontalAlignment="Left" Margin="0,14,0,0" />
                            </StackPanel>
                        </Border>
                    </ScrollViewer>
                    <Border Grid.Column="2" Style="{StaticResource Panel}">
                        <Grid><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                            <TextBlock Text="Campanhas confirmadas no banco" Foreground="{StaticResource TextPrimary}" FontSize="19" FontWeight="Bold" />
                            <DataGrid Grid.Row="1" ItemsSource="{Binding Campaigns}" SelectedItem="{Binding SelectedCampaign}" AutoGenerateColumns="False" IsReadOnly="True" Margin="0,12,0,0" SelectionChanged="CampaignSelectionChanged">
                                <DataGrid.Columns><DataGridTextColumn Header="Nome" Binding="{Binding Nome}" Width="*" /><DataGridTextColumn Header="Tipo" Binding="{Binding Tipo}" Width="100" /><DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="110" /><DataGridTextColumn Header="Segmento" Binding="{Binding SegmentoNome}" Width="130" /><DataGridTextColumn Header="ROAS" Binding="{Binding Roas, StringFormat=N2}" Width="75" /></DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Segmentos">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="0.8*" /><ColumnDefinition Width="12" /><ColumnDefinition Width="1.2*" /></Grid.ColumnDefinitions>
                    <Border Style="{StaticResource Panel}">
                        <StackPanel>
                            <DockPanel><TextBlock Text="Cadastro de segmento" Foreground="{StaticResource TextPrimary}" FontSize="19" FontWeight="Bold" /><Button Content="Novo" Click="NewSegment_Click" DockPanel.Dock="Right" Padding="14,6" /></DockPanel>
                            <TextBlock Text="Nome" Style="{StaticResource FieldLabel}" Margin="0,14,0,5" /><TextBox Text="{Binding SegmentName, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="Descrição" Style="{StaticResource FieldLabel}" Margin="0,10,0,5" /><TextBox Text="{Binding SegmentDescription, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" Height="65" />
                            <UniformGrid Columns="2" Margin="0,10,0,0">
                                <StackPanel Margin="0,0,10,10"><TextBlock Text="Cor" Style="{StaticResource FieldLabel}" /><TextBox Text="{Binding SegmentColor, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
                                <StackPanel Margin="0,0,0,10"><TextBlock Text="Prioridade" Style="{StaticResource FieldLabel}" /><TextBox Text="{Binding SegmentPriority, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
                                <StackPanel Margin="0,0,10,10"><TextBlock Text="Ticket mínimo" Style="{StaticResource FieldLabel}" /><TextBox Text="{Binding SegmentTicketMin, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
                                <StackPanel Margin="0,0,0,10"><TextBlock Text="Ticket máximo" Style="{StaticResource FieldLabel}" /><TextBox Text="{Binding SegmentTicketMax, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
                                <StackPanel Margin="0,0,10,10"><TextBlock Text="Frequência mínima" Style="{StaticResource FieldLabel}" /><TextBox Text="{Binding SegmentFrequencyMin, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
                                <StackPanel Margin="0,0,0,10"><TextBlock Text="Frequência máxima" Style="{StaticResource FieldLabel}" /><TextBox Text="{Binding SegmentFrequencyMax, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
                            </UniformGrid>
                            <CheckBox Content="Segmento ativo" IsChecked="{Binding SegmentActive}" Margin="0,4,0,0" />
                            <Button Content="Salvar segmento" Click="SaveSegment_Click" Padding="18,10" HorizontalAlignment="Left" Margin="0,14,0,0" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Style="{StaticResource Panel}">
                        <Grid><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                            <TextBlock Text="Segmentos confirmados no banco" Foreground="{StaticResource TextPrimary}" FontSize="19" FontWeight="Bold" />
                            <DataGrid Grid.Row="1" ItemsSource="{Binding Segments}" SelectedItem="{Binding SelectedSegment}" AutoGenerateColumns="False" IsReadOnly="True" Margin="0,12,0,0" SelectionChanged="SegmentSelectionChanged">
                                <DataGrid.Columns><DataGridTextColumn Header="Nome" Binding="{Binding Nome}" Width="*" /><DataGridTextColumn Header="Cor" Binding="{Binding Cor}" Width="95" /><DataGridTextColumn Header="Prioridade" Binding="{Binding Prioridade}" Width="95" /><DataGridCheckBoxColumn Header="Ativo" Binding="{Binding Ativo}" Width="70" /></DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

        <Border Grid.Row="6" Style="{StaticResource Panel}" Padding="14">
            <DockPanel><TextBlock Text="{Binding Status}" Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" /><Button Content="Excluir selecionado" Click="DeleteSelected_Click" DockPanel.Dock="Right" Margin="12,0,0,0" Padding="14,6" /></DockPanel>
        </Border>
    </Grid>
</Window>
