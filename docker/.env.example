# Environment template for development and production compose files.
# Copy this file to .env on the target host and fill real secrets there.
# Do not commit real .env files.

COMPOSE_PROJECT_NAME=nexum
REGISTRY=ghcr.io
API_IMAGE_TAG=main
FRONTEND_IMAGE_TAG=main
ASPNETCORE_ENVIRONMENT=Production
HTTP_PORT=80
HTTP_BIND_ADDRESS=127.0.0.1

MYSQL_ROOT_PASSWORD=
MYSQL_DATABASE=nexum_altivon
MYSQL_USER=nexum_app
MYSQL_PASSWORD=
MYSQL_BACKUP_USER=root
MYSQL_BACKUP_PASSWORD=

API_DEFAULT_CONNECTION=
API_NEXUM_CONNECTION=
API_GENESIS_CONNECTION=
JWT_SECRET_KEY=
REDIS_CONNECTION_STRING=redis:6379
BACKUP_RETENTION_DAYS=30
BACKUP_INTERVAL_SECONDS=86400
RESTORE_TEST_INTERVAL_SECONDS=604800
RESTORE_TEST_DATABASE_PREFIX=genesisgest_restore_test

STORAGE_PROVIDER=local
STORAGE_LOCAL_ROOT=/app/storage/anexos
STORAGE_PUBLIC_BASE_URL=https://api.nexumaltivon.com.br
STORAGE_SIGNING_KEY=
STORAGE_MAX_UPLOAD_BYTES=52428800
MINIO_ROOT_USER=nexumminio
MINIO_ROOT_PASSWORD=
S3_ENDPOINT=http://minio:9000
S3_BUCKET=nexum-anexos
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_FORCE_PATH_STYLE=true

ADMIN_EMAIL=admin@nexumaltivon.com
ADMIN_PASSWORD=
ADMIN_NAME=Administrador Nexum
ADMIN_ROLE=Gerente

MP_ACCESS_TOKEN=
SENDGRID_API_KEY=

OPENAI_ENABLED=false
OPENAI_API_KEY=
OPENAI_API_BASE_URL=https://api.openai.com/v1/
OPENAI_MODEL=gpt-4.1-mini
OPENAI_MODEL_YARA=gpt-4.1-mini
OPENAI_MODEL_SOPHIA=gpt-4.1-mini

FRONTEND_URL=https://www.nexumaltivon.com.br
API_URL=https://api.nexumaltivon.com.br

# Staging override values used by docker-compose.staging.yml.
STAGING_HTTP_PORT=8088
STAGING_FRONTEND_URL=
STAGING_API_URL=
STAGING_ADMIN_URL=
